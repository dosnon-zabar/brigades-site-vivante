# ============================================
# Copier ce fichier en .env.local puis remplir.
# Les valeurs prod sont gérées via Netlify UI.
# ============================================

# URL de base de l'API Chefmate (v1 du projet admin)
# Dev local : http://localhost:3000/api/v1
# Prod      : https://chefmate-admin.zabar.fr/api/v1
CHEFMATE_API_URL=

# Clé API de l'équipe (générée depuis l'admin : /equipes/[id] → API keys)
CHEFMATE_API_KEY=

# UUID de l'équipe propriétaire du site
CHEFMATE_TEAM_ID=
